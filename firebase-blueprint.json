{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "URL to profile picture" },
        "bio": { "type": "string", "description": "User's bio" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "Sketch": {
      "title": "Sketch",
      "description": "A saved sketch or generated artwork",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique sketch ID" },
        "userId": { "type": "string", "description": "Owner's user ID" },
        "prompt": { "type": "string", "description": "Prompt used for generation" },
        "style": { "type": "string", "description": "Art style used" },
        "imageUrl": { "type": "string", "description": "URL to the generated image" },
        "sketchUrl": { "type": "string", "description": "URL to the original sketch" },
        "createdAt": { "type": "number", "description": "Creation timestamp" },
        "analytics": {
          "type": "object",
          "properties": {
            "width": { "type": "number" },
            "height": { "type": "number" },
            "model": { "type": "string" }
          }
        }
      },
      "required": ["id", "userId", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/sketches/{sketchId}": {
      "schema": "Sketch",
      "description": "Collection of sketches and generated art"
    }
  }
}
